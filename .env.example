# ─────────────────────────────────────────────────────────────────────────────
# PagerMonitor — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ────────────────────────────────────────────────────────────────────

# Port to listen on (default: 3000)
PORT=3000

# Log level: error | warn | info | debug (default: info)
LOG_LEVEL=info

# Set to "true" if this server has NO RTL-SDR dongle attached
# (i.e. you are using remote RPi clients to forward messages)
# Set to "false" if the SDR dongle is connected directly to this machine
DISABLE_SDR=false


# ── SDR Settings (only needed when DISABLE_SDR=false) ────────────────────────

# Frequency to monitor (can use M suffix: 173.250M)
# Multiple frequencies: 173.250M:152.240M
RTL_FM_FREQ=173.250M

# RTL-SDR device index (0 = first dongle)
RTL_FM_DEVICE_INDEX=0

# Gain in dB (0 = auto AGC, 40 = typical starting point)
RTL_FM_GAIN=40

# Frequency correction in PPM (run rtl_test -p to find your value)
RTL_FM_PPM=0

# Squelch level (0 = disabled, increase to suppress noise)
RTL_FM_SQUELCH=0

# Modulation (fm = wideband FM, leave as-is for pagers)
RTL_FM_MODULATION=fm

# Sample rate (22050 works well for most pager protocols)
RTL_FM_SAMPLE_RATE=22050


# ── Decoder Settings ──────────────────────────────────────────────────────────

# Protocols to decode (space-separated)
# Options: POCSAG512 POCSAG1200 POCSAG2400 FLEX EAS
MULTIMON_PROTOCOLS=POCSAG1200

# Suppress multimon-ng info output (1 = quiet, 0 = verbose)
MULTIMON_QUIET=1

# Character set for POCSAG messages (-C flag). Possible values: US (default), FR, DE, SE, DK, SI
# MULTIMON_POCSAG_CHARSET=SI


# ── Database ──────────────────────────────────────────────────────────────────

# Path to the SQLite database file
# When using Docker, this should stay in /app/backend/data/
DB_PATH=./data/pagermonitor.db

# Path to the archive database (auto-created when archiving is enabled)
# ARCHIVE_PATH=./data/archive.db


# ── Security ──────────────────────────────────────────────────────────────────

# Default admin password for first run.
# If left unset, a random password is generated and printed in the logs:
#   docker logs pagermonitor | grep "Default admin"
# After first login, change password in Admin → Users
# DEFAULT_ADMIN_PASS=admin123


# ── Deduplication ─────────────────────────────────────────────────────────────

# Ignore duplicate messages within this window (seconds, 0 = disabled)
DEDUP_WINDOW_SECONDS=5
